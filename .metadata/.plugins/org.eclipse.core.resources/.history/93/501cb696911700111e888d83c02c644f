package numbers;

public class consecutive_swap_numbers {
	 public static void main(String[] args) {
	        int a=5;
	        int b=8;
	        
	        System.out.println("\nBefore Swapping: a = " + a + ", b = " + b);

	        int temp = a;
	        a = b;
	        b = temp;

	        System.out.println("After Swapping: a = " + a + ", b = " + b);

	       
	    }
	}
